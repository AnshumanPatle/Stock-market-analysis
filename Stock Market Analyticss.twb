      <aliases enabled='yes' />
      <column caption='Market Capitalisation' datatype='integer' name='[Calculation_1976111228522496]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[share_price]*[outstanding_shares]' />
      </column>
      <column caption='Average Trading Value' datatype='real' name='[Calculation_1976111233208321]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([volume])' />
      </column>
      <column caption='Daily Return' datatype='real' name='[Calculation_1976111233863682]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([close]) / LOOKUP(SUM([close]), -1)) - 1'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Volatility' datatype='real' name='[Calculation_1976111235215363]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_STDEV([Calculation_1976111233863682])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Dividend Yeild' datatype='real' name='[Calculation_1976111237021700]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([dividend_per_share (fact!dividends1)])/MAX([close]))*100' />
      </column>
      <column caption='Order Execution Rate ' datatype='real' name='[Calculation_1976111245344773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(COUNT(IF [status]=&quot;Filled&quot; THEN [order_id] END)/COUNT([order_id]))*100' />
      </column>
      <column caption='Sell Trades' datatype='real' name='[Calculation_1976111248990214]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [side]=&quot;SELL&quot; THEN [quantity]*[price] ELSE 0 END)' />
      </column>
      <column caption='Buy Trades' datatype='real' name='[Calculation_1976111249489927]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [side]=&quot;BUY&quot; THEN [quantity]*[price] ELSE 0 END)' />
      </column>
      <column caption='Trades Performance' datatype='real' name='[Calculation_1976111249846280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1976111248990214]-[Calculation_1976111249489927]' />
      </column>
      <column caption='Trades Win Count' datatype='integer' name='[Calculation_1976111250886665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(IF [Calculation_1976111249846280]&gt;0 THEN COUNT([order_id (fact!trades)]) else 0 END)' />
      </column>
      <column caption='Latest Prize' datatype='real' name='[Calculation_1976111280902163]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX({FIXED [company_id] : MAX(IF [date] = {MAX([date])} THEN [close] END)})' />
      </column>
      <column caption='PortfolioValue' datatype='real' name='[Calculation_1976111281332244]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([quantity]) * ([Calculation_1976111280902163])' />
      </column>
      <column caption='Portfolio Return %' datatype='real' name='[Calculation_1976111284031512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([Calculation_1976111281332244]-[PortfolioValue (copy)_1976111283777559])/[PortfolioValue (copy)_1976111283777559])*100' />
      </column>
      <column caption='Sharpe Ratio' datatype='real' name='[Calculation_1976111284998169]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1976111284031512]-0)/[Calculation_1976111235215363]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Initial Prize' datatype='real' name='[Latest Prize (copy)_1976111283535894]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN({FIXED [company_id] : MIN(IF [date] = {MIN([date])} THEN [close] END)})' />
      </column>
      <column caption='Initial PortfolioValue' datatype='real' name='[PortfolioValue (copy)_1976111283777559]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([quantity]) * ([Latest Prize (copy)_1976111283535894])' />
      </column>
